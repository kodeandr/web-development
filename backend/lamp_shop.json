{
  "info": {
    "name": "Интернет-магазин лампочек (микросервисы)",
    "description": "Коллекция для проверки микросервисов товаров (port 8000) и заказов (port 8001)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Товары (product-service)",
      "item": [
        {
          "name": "Получить категории",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/categories",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["categories"]
            }
          }
        },
        {
          "name": "Список товаров (с фильтрацией и пагинацией)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/products?category_id=1&min_price=100&max_price=500&limit=10&offset=0",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["products"],
              "query": [
                { "key": "category_id", "value": "1" },
                { "key": "min_price", "value": "100" },
                { "key": "max_price", "value": "500" },
                { "key": "limit", "value": "10" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "Получить товар по ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/products/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["products", "1"]
            }
          }
        },
        {
          "name": "Создать товар",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category_id\": 2,\n  \"sku\": \"LMP-TEST-01\",\n  \"name\": \"Тестовая лампа LED 9W\",\n  \"description\": \"Тестовое описание\",\n  \"power_watt\": 9,\n  \"lumen\": 850,\n  \"color_temp_k\": 4000,\n  \"life_hours\": 20000,\n  \"price\": 349.99,\n  \"stock_quantity\": 15\n}"
            },
            "url": {
              "raw": "http://localhost:8000/products",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["products"]
            }
          }
        },
        {
          "name": "Обновить товар (частичное обновление)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 299.99,\n  \"stock_quantity\": 20\n}"
            },
            "url": {
              "raw": "http://localhost:8000/products/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["products", "1"]
            }
          }
        },
        {
          "name": "Удалить товар (мягкое удаление)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/products/2",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["products", "2"]
            }
          }
        },
        {
          "name": "Загрузить изображение для товара",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": "C:/path/to/your/lightbulb.jpg"
                },
                {
                  "key": "is_main",
                  "value": "true",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "http://localhost:8000/products/1/images",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["products", "1", "images"]
            }
          }
        }
      ]
    },
    {
      "name": "Заказы (order-service)",
      "item": [
        {
          "name": "Создать заказ (с проверкой остатков)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_name\": \"Иван Петров\",\n  \"customer_phone\": \"+7 999 123-45-67\",\n  \"customer_email\": \"ivan@example.com\",\n  \"delivery_address\": \"г. Москва, ул. Ленина, д. 1, кв. 5\",\n  \"payment_method\": \"card\",\n  \"items\": [\n    { \"product_id\": 1, \"quantity\": 2, \"price\": 199.99 },\n    { \"product_id\": 3, \"quantity\": 1, \"price\": 399.99 }\n  ]\n}"
            },
            "url": {
              "raw": "http://localhost:8001/orders",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8001",
              "path": ["orders"]
            }
          }
        },
        {
          "name": "Получить заказ по номеру",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8001/orders/ORD-20250410120000-abc1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8001",
              "path": ["orders", "ORD-20250410120000-abc1"]
            }
          }
        },
        {
          "name": "Список заказов (с фильтром по статусу)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8001/orders?status_id=1&limit=20",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8001",
              "path": ["orders"],
              "query": [
                { "key": "status_id", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Обновить статус заказа",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status_id\": 2\n}"
            },
            "url": {
              "raw": "http://localhost:8001/orders/ORD-20250410120000-abc1/status",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8001",
              "path": ["orders", "ORD-20250410120000-abc1", "status"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url_products",
      "value": "http://localhost:8000"
    },
    {
      "key": "base_url_orders",
      "value": "http://localhost:8001"
    }
  ]
}